NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/sexappeal
JWT_SECRET=
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
# Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console)
# Required for "Continue with Google" on login/register. Must match Authorized JavaScript origins:
#   https://sexappeal.drsrv.net.ar
#   http://localhost:5000
GOOGLE_CLIENT_ID=
# Non-admin browser sessions auto-logout after 1 min idle (public/js/sessionIdle.js).

# Server watch — run ONLY from your Windows admin PC (never on 91.208.206.35)
# Probes TCP from outside; refuses to run on the production server filesystem.
WATCH_SERVER_IP=91.208.206.35
WATCH_TCP_PORT=22
# Or multiple ports (any open = reachable): WATCH_TCP_PORTS=22,443
# Default platform WhatsApp origin (also editable in Admin → Dashboard Config)
WATCH_ALERT_WHATSAPP=5491178280156
# Default recipient for scripts/send-test-whatsapp-twilio.js (E.164, no +)
WHATSAPP_TEST_PHONE=5491134679434
# Optional: instant WhatsApp via CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# WATCH_CALLMEBOT_API_KEY=
WATCH_TCP_PORT=443
WATCH_REMIND_MINUTES=30
# Set to 1 to also email admin@drsrv.net.ar if WhatsApp fails
WATCH_EMAIL_FALLBACK=0
WATCH_ALERT_EMAIL=admin@drsrv.net.ar

# SMTP (required for server-watch alerts and platform email)
SMTP_HOST=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
FROM_NAME=SexAppeal
FROM_EMAIL=

# Public site URL for SEO (sitemap, canonical, Open Graph)
PLATFORM_URL=https://sexappeal.drsrv.net.ar

# WhatsApp outreach step-2 register links (neutral alias — replaced fcwa.drsrv.net.ar)
# Unset = selfappeal.drsrv.net.ar; empty string = no link in step-2 replies
# WhatsApp outreach batch drip (in-app Admin → Invitations)
# 5 batches × 50 msgs, 30 min apart = 250 cold sends/day (Meta tier default)
# WHATSAPP_DRIP_BATCH_SIZE=50
# WHATSAPP_DRIP_BATCH_PAUSE_MINUTES=30
# WHATSAPP_DRIP_BATCHES_PER_DAY=5
# WHATSAPP_DRIP_INTER_DELAY_MS=0
WHATSAPP_DRIP_ALIAS_DOMAIN=selfappeal.drsrv.net.ar

# Minimum active professionals required to publish a location SEO page
SEO_LOCATION_MIN_COUNT=1

# Production VPS IP (always trusted). Your home IP is added automatically on each admin login.
ADMIN_TRUSTED_IPS=91.208.206.35,181.14.38.249

# SMS / Twilio — npm package is installed on deploy (docker-compose INSTALL_TWILIO defaults to 1).
# Set TWILIO_SENDER_BYPASS=false once creds + sender are configured on the server .env.
# SMS_ENABLED=false
# TWILIO_SENDER_BYPASS=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Twilio WhatsApp Business sender (platform origin number — E.164, e.g. +54911... or 54911...)
# When set, admin UI uses this instead of a manually saved phone. Also used if TWILIO_FROM_NUMBER is set and this is empty.
# Twilio WhatsApp sender (E.164 digits, e.g. 15559340276 for +1 555-934-0276)
TWILIO_WHATSAPP_FROM_NUMBER=
# Use Twilio WhatsApp API instead of QR (auto when TWILIO_WHATSAPP_FROM_NUMBER is set).
# TWILIO_WHATSAPP_API=true
# Send cold invitations NOW (no Meta template): set true, recreate app, scan QR in Admin.
# WHATSAPP_USE_WEBJS=true
# Meta WhatsApp templates (Content → Twilio Console)
# ACTIVE — watext (approved, use for cold drip now):
TWILIO_WHATSAPP_CONTENT_SID=HX92a57f64dfa083cb94b884da55a85cde
# PENDING/REJECTED — watext_updated (do NOT set until a NEW template is Approved):
# TWILIO_WHATSAPP_CONTENT_SID=HX3e76b50fc1f69871bfbc4404c7666482
# Step 1 only: {{1}} = lead alias. Body must match getColdOutreachTemplateBodySample() in code.
# TWILIO_WA_TEMPLATE_EXAMPLE_1=María
# Public HTTPS image for WhatsApp media (default: https://selfappeal.drsrv.net.ar/images/outreach-logo.png)
# Generate locally: node scripts/generate-outreach-logo.js
# TWILIO_WHATSAPP_MEDIA_URL=https://selfappeal.drsrv.net.ar/images/outreach-logo.png
# Inbound replies webhook (set on Twilio WhatsApp sender → "When a message comes in"):
# https://sexappeal.drsrv.net.ar/api/v1/webhooks/twilio/whatsapp
# TWILIO_WHATSAPP_WEBHOOK_URL=https://sexappeal.drsrv.net.ar/api/v1/webhooks/twilio/whatsapp
# TWILIO_WEBHOOK_SKIP_VALIDATE=true
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
